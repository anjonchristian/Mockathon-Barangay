# Server Configuration
PORT=3000

# MongoDB Configuration
# Local MongoDB: mongodb://localhost:27017/ekap
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/ekap
MONGODB_URI=mongodb://localhost:27017/ekap

# Gemini AI API Key
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Service Account (Optional - for admin operations)
# Path to your service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json